{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for Llama Studio: sidecar shell, scoped FS, dialog, and our custom commands for secrets / patch / workspace.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:scope-home-recursive"
  ]
}
