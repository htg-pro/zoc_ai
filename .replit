modules = ["nodejs-20", "python-3.11", "rust-stable", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Zoc"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd llama-web && pnpm dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Zoc"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd zoc-model && PYTHONPATH=src python -m zoc"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
