ass=\"text-[12px] text-[#E4E4E7] flex-1 truncate\" data-kid=\"396\">Add a settings page</span>\n            <i data-lucide=\"arrow-up-right\" class=\"w-3 h-3 text-[#3F3F46] shrink-0\" data-kid=\"397\"></i>\n          </button>\n          <button class=\"w-full h-9 rounded-lg bg-[#15151A] border border-[#26262B] hover:border-[rgba(155,106,241,0.45)] hover:bg-[#17171D] flex items-center gap-2.5 px-3 text-left\" data-kid=\"398\">\n            <i data-lucide=\"book-open\" class=\"w-3.5 h-3.5 text-[#71717A] shrink-0\" data-kid=\"399\"></i>\n            <span class=\"text-[12px] text-[#E4E4E7] flex-1 truncate\" data-kid=\"400\">Explain this repo</span>\n            <i data-lucide=\"arrow-up-right\" class=\"w-3 h-3 text-[#3F3F46] shrink-0\" data-kid=\"401\"></i>\n          </button>\n        </div>\n\n        <div class=\"mt-5\" data-kid=\"402\">\n          <div class=\"flex items-center gap-1.5 mb-1.5\" data-kid=\"403\">\n            <i data-lucide=\"history\" class=\"w-2.5 h-2.5 text-[#52525B]\" data-kid=\"404\"></i>\n            <span class=\"text-[9.5px] font-semibold uppercase tracking-[0.09em] text-[#52525B]\" data-kid=\"405\">Recent runs</span>\n          </div>\n          <button class=\"w-full h-8 rounded-md hover:bg-[#15151A] flex items-center gap-2 px-2 text-left\" data-kid=\"406\">\n            <i data-lucide=\"circle-check\" class=\"w-3.5 h-3.5 text-[#34D399] shrink-0\" data-kid=\"407\"></i>\n            <span class=\"text-[11.5px] text-[#A1A1AA] flex-1 truncate\" data-kid=\"408\">Validate and prepare review diff</span>\n            <span class=\"ls-mono text-[9.5px] text-[#52525B] shrink-0\" data-kid=\"409\">12m ago</span>\n          </button>\n          <button class=\"w-full h-8 rounded-md hover:bg-[#15151A] flex items-center gap-2 px-2 text-left\" data-kid=\"410\">\n            <i data-lucide=\"circle-check\" class=\"w-3.5 h-3.5 text-[#34D399] shrink-0\" data-kid=\"411\"></i>\n            <span class=\"text-[11.5px] text-[#A1A1AA] flex-1 truncate\" data-kid=\"412\">Add data, interactions and polish</span>\n            <span class=\"ls-mono text-[9.5px] text-[#52525B] shrink-0\" data-kid=\"413\">38m ago</span>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 border-t border-[#1E1E23] p-3\" data-kid=\"414\">\n        <div class=\"rounded-[10px] bg-[#131318] border border-[#26262B] p-2.5\" data-kid=\"415\">\n          <p class=\"text-[12.5px] text-[#52525B] min-h-[38px] px-0.5 pt-0.5\" data-kid=\"416\">Ask the agent…</p>\n          <div class=\"flex items-center gap-1.5 mt-1.5\" data-kid=\"417\">\n            <button class=\"w-7 h-7 rounded-md flex items-center justify-center text-[#71717A] hover:bg-[#1B1B21] shrink-0\" title=\"Attach files\" data-kid=\"418\"><i data-lucide=\"paperclip\" class=\"w-3.5 h-3.5\" data-kid=\"419\"></i></button>\n            <div class=\"flex items-center bg-[#0E0E11] border border-[#26262B] rounded-md p-0.5 shrink-0\" data-kid=\"420\">\n              <button class=\"h-[20px] px-2 rounded text-[10.5px] text-[#71717A]\" data-kid=\"421\">Plan</button>\n              <button class=\"h-[20px] px-2 rounded bg-[rgba(155,106,241,0.16)] text-[10.5px] font-medium text-[#C9ADF8]\" data-kid=\"422\">Build</button>\n            </div>\n            <button class=\"h-6 px-2 rounded-md bg-[#15151A] border border-[#26262B] hover:border-[#3F3F46] flex items-center gap-1.5 shrink-0\" title=\"Autonomy level\" data-kid=\"423\">\n              <span class=\"w-[5px] h-[5px] rounded-full bg-[#FB923C]\" data-kid=\"424\"></span>\n              <span class=\"text-[10.5px] text-[#A1A1AA]\" data-kid=\"425\">High</span>\n              <i data-lucide=\"chevron-down\" class=\"w-2.5 h-2.5 text-[#52525B]\" data-kid=\"426\"></i>\n            </button>\n            <div class=\"flex-1\" data-kid=\"427\"></div>\n            <div class=\"flex items-center gap-1.5 shrink-0\" title=\"Context used\" data-kid=\"428\">\n              <svg class=\"w-3.5 h-3.5 -rotate-90\" viewBox=\"0 0 16 16\" data-kid=\"429\"></svg>\n              <span class=\"ls-mono text-[9.5px] text-[#71717A]\" data-kid=\"432\">0 / 8.2k</span>\n            </div>\n            <button class=\"w-7 h-7 rounded-lg bg-[#9B6AF1] hover:bg-[#A87DF5] flex items-center justify-center shrink-0\" title=\"Send\" data-kid=\"433\"><i data-lucide=\"arrow-up\" class=\"w-3.5 h-3.5 text-white\" data-kid=\"434\"></i></button>\n          </div>\n        </div>\n        <div class=\"flex items-center gap-1.5 mt-2 px-0.5\" data-kid=\"435\">\n          <i data-lucide=\"shield-check\" class=\"w-3 h-3 text-[#34D399]\" data-kid=\"436\"></i>\n          <span class=\"text-[10.5px] text-[#71717A]\" data-kid=\"437\">Ready · changes stay isolated until review</span>\n        </div>\n      </div>\n    </aside>\n  </div>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"438\"></script>\n<script data-kid=\"439\">lucide.createIcons({ attrs: { 'stroke-width': 1.75 } });</script>",
