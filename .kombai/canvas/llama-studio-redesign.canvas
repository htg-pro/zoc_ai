      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');\n\n  .ls-root{font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;}\n  .mono{font-family:'JetBrains Mono',ui-monospace,SFMono-Regular,monospace;}\n  svg.lucide{stroke-width:1.75px;}\n\n  /* ---- motion ---- */\n  @keyframes ls-pulse-dot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(155,106,241,.45);}50%{opacity:.55;box-shadow:0 0 0 5px rgba(155,106,241,0);}}\n  .pulse-dot{animation:ls-pulse-dot 1.6s ease-in-out infinite;}\n  @keyframes ls-shimmer{0%{transform:translateX(-120%);}100%{transform:translateX(340%);}}\n  .shimmer{animation:ls-shimmer 2.4s linear infinite;}\n  @keyframes ls-blink{0%,49%{opacity:1;}50%,100%{opacity:0;}}\n  .caret{display:inline-block;width:2px;height:14px;margin-left:2px;vertical-align:middle;background:#9B6AF1;animation:ls-blink 1s steps(1) infinite;}\n  .caret-block{display:inline-block;width:7px;height:13px;margin-left:1px;vertical-align:middle;background:#9B6AF1;animation:ls-blink 1.1s steps(1) infinite;}\n  @keyframes ls-typing{0%,80%,100%{opacity:.2;transform:translateY(0);}40%{opacity:1;transform:translateY(-1px);}}\n  .tdot{width:3px;height:3px;border-radius:9999px;background:#9B6AF1;display:inline-block;animation:ls-typing 1.2s ease-in-out infinite;}\n  @keyframes ls-fadein{from{opacity:0;transform:translateY(3px);}to{opacity:1;transform:none;}}\n  .fade-row{animation:ls-fadein .45s ease-out both;}\n\n  /* ---- editor ---- */\n  .code-line{display:flex;align-items:center;height:21px;border-left:2px solid transparent;position:relative;}\n  .ln{width:38px;flex-shrink:0;text-align:right;padding-right:16px;color:#52525B;font-size:11px;font-family:'JetBrains Mono',monospace;user-select:none;}\n  .code{white-space:pre;font-size:12.5px;color:#ABB2BF;font-family:'JetBrains Mono',monospace;}\n  .hl{background:rgba(155,106,241,0.08);border-left-color:#9B6AF1;}\n  .tk-k{color:#C678DD;}.tk-s{color:#98C379;}.tk-f{color:#61AFEF;}.tk-t{color:#E5C07B;}.tk-c{color:#5C6370;font-style:italic;}.tk-p{color:#ABB2BF;}\n\n  /* ---- scrollbars ---- */\n  .scroll-slim{scrollbar-width:thin;scrollbar-color:#26262B transparent;}\n  .scroll-slim::-webkit-scrollbar{width:8px;}\n  .scroll-slim::-webkit-scrollbar-thumb{background:#26262B;border-radius:4px;}\n  .scroll-slim::-webkit-scrollbar-track{background:transparent;}\n</style>\n\n<div class=\"ls-root w-full h-[900px] flex flex-col overflow-hidden bg-[#0E0E11] text-[#FAFAFA] select-none\" data-kid=\"1\">\n\n  \n  <div class=\"relative h-[38px] shrink-0 flex items-center gap-3 px-3 bg-[#101014] border-b border-[#1E1E23]\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2.5 text-[#52525B]\" data-kid=\"3\">\n      <i data-lucide=\"minus\" class=\"w-3 h-3\" aria-label=\"Minimize\" data-kid=\"4\"></i>\n      <i data-lucide=\"square\" class=\"w-2.5 h-2.5\" aria-label=\"Maximize\" data-kid=\"5\"></i>\n      <i data-lucide=\"x\" class=\"w-3 h-3\" aria-label=\"Close\" data-kid=\"6\"></i>\n    </div>\n    <div class=\"w-px h-4 bg-[#26262B]\" data-kid=\"7\"></div>\n    <div class=\"flex items-center gap-2\" data-kid=\"8\">\n      <span class=\"w-5 h-5 rounded-[6px] bg-gradient-to-br from-[#7C3AED] to-[#9B6AF1] flex items-center justify-center shadow-[0_2px_8px_rgba(124,58,237,0.35)]\" data-kid=\"9\">\n        <i data-lucide=\"sparkles\" class=\"w-3 h-3 text-white\" data-kid=\"10\"></i>\n      </span>\n      <span class=\"text-[12.5px] font-medium text-[#FAFAFA]\" data-kid=\"11\">Llama Studio</span>\n    </div>\n    <div class=\"w-px h-4 bg-[#26262B]\" data-kid=\"12\"></div>\n    <span class=\"mono text-[11px] text-[#71717A]\" data-kid=\"13\">/home/sanjeevtg/Documents/Zoom</span>\n    <span class=\"flex items-center gap-1 h-5 px-1.5 rounded-md bg-[#15151A] border border-[#1E1E23] text-[#A1A1AA]\" data-kid=\"14\">\n      <i data-lucide=\"git-branch\" class=\"w-3 h-3\" data-kid=\"15\"></i>\n      <span class=\"text-[11px]\" data-kid=\"16\">main</span>\n    </span>\n\n    \n    <div class=\"absolute left-1/2 -translate-x-1/2 w-[340px] h-[26px] flex items-center gap-2 px-2.5 rounded-md bg-[#15151A] border border-[#26262B]\" data-kid=\"17\">\n      <i data-lucide=\"search\" class=\"w-3 h-3 text-[#52525B]\" data-kid=\"18\"></i>\n      <span class=\"text-[11.5px] text-[#52525B]\" data-kid=\"19\">Search files, commands, settings…</span>\n      <span class=\"ml-auto mono text-[10px] text-[#71717A] px-1 py-px rounded bg-[#1B1B21] border border-[#26262B]\" data-kid=\"20\">⌘K</span>\n    </div>\n\n    <div class=\"ml-auto flex items-center gap-1.5\" data-kid=\"21\">\n      <span class=\"w-7 h-7 flex items-center justify-center rounded-md text-[#71717A]\" data-kid=\"22\"><i data-lucide=\"panel-left\" class=\"w-3.5 h-3.5\" data-kid=\"23\"></i></span>\n      <span class=\"w-7 h-7 flex items-center justify-center rounded-md text-[#A1A1AA] bg-[#1B1B21]\" data-kid=\"24\"><i data-lucide=\"panel-bottom\" class=\"w-3.5 h-3.5\" data-kid=\"25\"></i></span>\n      <span class=\"w-7 h-7 flex items-center justify-center rounded-md text-[#A1A1AA] bg-[#1B1B21]\" data-kid=\"26\"><i data-lucide=\"panel-right\" class=\"w-3.5 h-3.5\" data-kid=\"27\"></i></span>\n      <button class=\"ml-1 flex items-center gap-1.5 h-[26px] px-2.5 rounded-md bg-[rgba(155,106,241,0.12)] border border-[rgba(155,106,241,0.4)]\" aria-label=\"Agent is running\" data-kid=\"28\">\n        <i data-lucide=\"loader-circle\" class=\"w-3 h-3 text-[#9B6AF1] animate-spin\" data-kid=\"29\"></i>\n        <span class=\"text-[11.5px] font-medium text-[#B59CF5]\" data-kid=\"30\">Running…</span>\n        <span class=\"mono text-[10px] text-[#9B6AF1]\" data-kid=\"31\">4m 12s</span>\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"flex-1 flex min-h-0\" data-kid=\"32\">\n\n    \n    <div class=\"w-12 shrink-0 flex flex-col items-center py-2 bg-[#101014] border-r border