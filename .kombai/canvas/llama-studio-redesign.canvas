      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');\n.f-sans{font-family:'Inter',system-ui,sans-serif}\n.f-mono{font-family:'JetBrains Mono',ui-monospace,SFMono-Regular,monospace}\n.k-scroll::-webkit-scrollbar{width:6px;height:6px}\n.k-scroll::-webkit-scrollbar-thumb{background:#26262B;border-radius:3px}\n.k-scroll::-webkit-scrollbar-track{background:transparent}\n</style>\n\n<div class=\"f-sans w-full flex flex-col bg-[#0E0E11] text-[#FAFAFA] overflow-hidden antialiased\" style=\"font-family:'Inter',system-ui,sans-serif;height:100vh;min-height:780px\" data-kid=\"1\">\n\n  \n  <div class=\"h-[38px] shrink-0 flex items-center px-3 gap-3 bg-[#0E0E11] border-b border-[#1E1E23]\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2 text-[#52525B]\" data-kid=\"3\">\n      <i data-lucide=\"minus\" class=\"w-3.5 h-3.5\" data-kid=\"4\"></i>\n      <i data-lucide=\"square\" class=\"w-3 h-3\" data-kid=\"5\"></i>\n      <i data-lucide=\"x\" class=\"w-3.5 h-3.5\" data-kid=\"6\"></i>\n    </div>\n    <div class=\"w-px h-4 bg-[#26262B]\" data-kid=\"7\"></div>\n    <div class=\"flex items-center gap-2\" data-kid=\"8\">\n      <div class=\"w-[18px] h-[18px] rounded-[5px] flex items-center justify-center\" style=\"background:linear-gradient(135deg,#9B6AF1,#7C3AED)\" data-kid=\"9\">\n        <i data-lucide=\"sparkles\" class=\"w-[11px] h-[11px] text-white\" data-kid=\"10\"></i>\n      </div>\n      <span class=\"text-[12.5px] font-medium text-[#E4E4E7]\" data-kid=\"11\">Llama Studio</span>\n    </div>\n    <div class=\"w-px h-4 bg-[#26262B]\" data-kid=\"12\"></div>\n    <span class=\"f-mono text-[11.5px] text-[#71717A]\" data-kid=\"13\">/home/sanjeevtg/Documents/Zoom</span>\n    <div class=\"flex items-center gap-1.5 h-[20px] px-1.5 rounded-md bg-[#15151A] border border-[#26262B]\" data-kid=\"14\">\n      <i data-lucide=\"git-branch\" class=\"w-3 h-3 text-[#