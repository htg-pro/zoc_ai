{
  "name": "@zoc-studio/shared-types",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "schema:generate": "python ../scripts/generate_ts.py",
    "schema:check": "python ../scripts/generate_ts.py --check"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
