{
  "name": "zoc-studio",
  "version": "0.0.1",
  "private": true,
  "description": "Zoc AI \u2014 Zencoder/Codex-style local agentic coding desktop app.",
  "scripts": {
    "dev": "python3 scripts/stage_dev_binaries.py && pnpm --filter @zoc-studio/desktop dev",
    "dev:frontend": "pnpm --filter @zoc-studio/frontend dev",
    "dev:agent": "uv run --package zocai-gateway python -m zocai_gateway.scripts.launch",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format",
    "schema:generate": "python packages/shared-types/scripts/generate_ts.py",
    "schema:check": "python packages/shared-types/scripts/generate_ts.py --check",
    "check": "pnpm schema:check && pnpm lint && pnpm typecheck && pnpm --filter @zoc-studio/agent... check && cargo check --workspace",
    "version:stamp": "python3 scripts/stamp_version.py",
    "sidecar:bundle": "python3 scripts/bundle_sidecar.py",
    "tauri:prepare": "bash scripts/prepare_tauri_build.sh",
    "release": "bash scripts/release.sh",
    "zip": "bash scripts/release.sh && bash scripts/make_zip.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@babel/helper-string-parser": "7.29.7",
    "@babel/traverse": "7.29.7"
  }
}
